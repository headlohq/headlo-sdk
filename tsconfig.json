{
  "compilerOptions": {
    "target":            "ES2020",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "jsx":               "react-jsx",
    "strict":            true,
    "declaration":       true,
    "skipLibCheck":        true,
    "ignoreDeprecations":  "6.0",
    "esModuleInterop":   true
  },
  "include": ["src"]
}
